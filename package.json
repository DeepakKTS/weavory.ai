{
  "name": "@weavory/mcp",
  "version": "0.1.7",
  "description": "weavory.ai — Shared belief coordination substrate for AI agents. MCP-native, NANDA AgentFacts-compatible.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "DeepakKTS",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeepakKTS/weavory.ai.git"
  },
  "homepage": "https://github.com/DeepakKTS/weavory.ai#readme",
  "bugs": {
    "url": "https://github.com/DeepakKTS/weavory.ai/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "weavory": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs/README.md",
    "docs/ARCHITECTURE.md",
    "docs/DEPLOYMENT.md",
    "docs/COMPLIANCE.md",
    "docs/RUNBOOK.md",
    "docs/SECURITY.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "dev": "tsx src/mcp/server.ts",
    "start": "node dist/cli.js",
    "test": "vitest run --reporter=default --reporter=json --outputFile=ops/data/tests.json",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage --coverage.reporter=json --coverage.reporter=text",
    "collect:git": "tsx scripts/collect/git.ts",
    "collect:all": "pnpm collect:git",
    "dashboard:serve": "tsx scripts/serve-dashboard.ts",
    "verify:gate1": "bash scripts/verify/gate1.sh",
    "verify:gate2": "bash scripts/verify/gate2.sh",
    "verify:gate3": "bash scripts/verify/gate3.sh",
    "verify:gate4": "bash scripts/verify/gate4.sh",
    "verify:gate5": "bash scripts/verify/gate5.sh",
    "verify:gate6": "bash scripts/verify/gate6.sh",
    "verify:gate7": "bash scripts/verify/gate7.sh",
    "bench": "tsx scripts/bench/throughput.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "hono": "^4.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "agent-memory",
    "shared-memory",
    "coordination",
    "belief",
    "trust",
    "audit",
    "bi-temporal",
    "responsible-ai",
    "governance",
    "provenance",
    "ed25519",
    "blake3"
  ],
  "optionalDependencies": {
    "@duckdb/node-api": "1.5.2-r.1"
  }
}
