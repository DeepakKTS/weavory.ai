{
  "name": "@weavory/mcp",
  "version": "0.1.0",
  "description": "weavory.ai — Shared belief coordination substrate for AI agents. MCP-native, NANDA AgentFacts-compatible.",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "weavory": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "docs/README.md",
    "docs/QUICKSTART.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/mcp/server.ts",
    "start": "node dist/cli.js",
    "test": "vitest run --reporter=default --reporter=json --outputFile=ops/data/tests.json",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage --coverage.reporter=json --coverage.reporter=text",
    "collect:git": "tsx scripts/collect/git.ts",
    "collect:tests": "tsx scripts/collect/tests.ts",
    "collect:runtime": "tsx scripts/collect/runtime.ts",
    "collect:all": "pnpm collect:git && pnpm collect:tests && pnpm collect:runtime",
    "dashboard:serve": "tsx scripts/serve-dashboard.ts",
    "verify:gate1": "bash scripts/verify/gate1.sh",
    "verify:gate2": "bash scripts/verify/gate2.sh",
    "verify:gate3": "bash scripts/verify/gate3.sh",
    "verify:gate4": "bash scripts/verify/gate4.sh",
    "verify:gate5": "bash scripts/verify/gate5.sh",
    "verify:gate6": "bash scripts/verify/gate6.sh",
    "verify:gate7": "bash scripts/verify/gate7.sh",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "hono": "^4.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "shared-memory",
    "coordination",
    "nanda",
    "belief",
    "agent-facts",
    "bi-temporal",
    "crdt"
  ]
}
